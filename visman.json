{
  "vm_state": {
    "score": 0
  },
  "canvasLayer": [
    {
      "id": "cannon",
      "context": "canvas",
      "type": "polygon",
      "position": {
        "x": 320,
        "y": 330
      },
      "size": {
        "width": 50,
        "height": 30
      },
      "rotation": {
        "z": -1.5708
      },
      "properties": {
        "points": [
          {
            "x": 50,
            "y": 15
          },
          {
            "x": 0,
            "y": 0
          },
          {
            "x": 0,
            "y": 30
          }
        ]
      },
      "style": {
        "fillStyle": "#4CAF50",
        "strokeStyle": "#2E7D32",
        "lineWidth": 2
      },
      "physics": {
        "kinematic": true,
        "bodyType": "kinematic"
      },
      "actions": {
        "aim_left": {
          "rotation": {
            "delta": {
              "z": -0.05
            }
          }
        },
        "aim_right": {
          "rotation": {
            "delta": {
              "z": 0.05
            }
          }
        },
        "fire": {
          "spawn": {
            "template": {
              "context": "canvas",
              "type": "circle",
              "size": {
                "radius": 8
              },
              "style": {
                "fillStyle": "#FF5722",
                "strokeStyle": "#E64A19",
                "lineWidth": 2
              },
              "physics": {
                "kinematic": true,
                "bodyType": "dynamic",
                "destroyOutOfBounds": true
              },
              "collision": {
                "collisionGroups": [
                  "bullets"
                ],
                "collidesWith": [
                  "targets"
                ],
                "onCollision": "destroy_on_collision"
              },
              "actions": {
                "destroy_on_collision": {
                  "destroy": true
                }
              }
            },
            "speed": 500,
            "velocityRelativeToRotation": true,
            "offset": {
              "x": 25,
              "y": 0
            },
            "offsetFrom": "center"
          }
        }
      },
      "callbacks": {
        "onKeyHeld": {
          "ArrowLeft": "aim_left",
          "ArrowRight": "aim_right"
        },
        "onKeyDown": {
          " ": "fire"
        }
      }
    },
    {
      "id": "target-{index}",
      "repeat": {
        "count": 5
      },
      "context": "canvas",
      "type": "rectangle",
      "position": {
        "x": "{{ 90 + index * 110 }}",
        "y": 80
      },
      "size": {
        "width": 60,
        "height": 60
      },
      "style": {
        "fillStyle": "#E53935",
        "strokeStyle": "#B71C1C",
        "lineWidth": 2
      },
      "physics": {
        "kinematic": true,
        "bodyType": "static"
      },
      "collision": {
        "collisionGroups": [
          "targets"
        ],
        "onCollision": "destroy_self",
        "stateMutations": [
          {
            "path": "vm.score",
            "operation": "increment",
            "value": 10
          }
        ]
      },
      "actions": {
        "destroy_self": {
          "destroy": true
        }
      }
    }
  ],
  "domLayer": [
    {
      "id": "score",
      "context": "dom",
      "type": "div",
      "position": {
        "x": 20,
        "y": 20
      },
      "properties": {
        "text": "SCORE: {{ @vm.score }}"
      },
      "style": {
        "color": "#4CAF50",
        "fontSize": 28,
        "fontWeight": "bold",
        "fontFamily": "monospace"
      }
    },
    {
      "id": "title",
      "context": "dom",
      "type": "div",
      "position": {
        "x": 240,
        "y": 20
      },
      "properties": {
        "text": "FIRING RANGE"
      },
      "style": {
        "color": "#FFFFFF",
        "fontSize": 32,
        "fontWeight": "bold",
        "fontFamily": "monospace"
      }
    },
    {
      "id": "instructions",
      "context": "dom",
      "type": "div",
      "position": {
        "x": 180,
        "y": 330
      },
      "properties": {
        "text": "← → to aim (HOLD) | SPACE to fire"
      },
      "style": {
        "color": "#888888",
        "fontSize": 14,
        "fontFamily": "monospace"
      }
    }
  ]
}
